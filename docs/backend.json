
{
  "entities": {
    "Book": {
      "title": "Book",
      "description": "Information about an uploaded PDF book.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "classId": { "type": "string" },
        "subject": { "type": "string" },
        "chapterName": { "type": "string", "description": "Name of the specific chapter for guide books." },
        "fileName": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "coverImageUrl": { "type": "string", "description": "URL to the book's cover image." },
        "isGuide": { "type": "boolean", "default": false },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["classId", "subject", "fileName", "pdfUrl", "userId"]
    },
    "QuestionSet": {
      "title": "Question Set",
      "description": "A collection of questions for an exam.",
      "type": "object",
      "properties": {
        "institution": { "type": "string" },
        "exam": { "type": "string" },
        "classId": { "type": "string" },
        "subject": { "type": "string" },
        "time": { "type": "string" },
        "totalMarks": { "type": "string" },
        "creativeInstruction": { "type": "string" },
        "shortInstruction": { "type": "string" },
        "mcqInstruction": { "type": "string" },
        "marksA": { "type": "number" },
        "marksB": { "type": "number" },
        "marksC": { "type": "number" },
        "marksD": { "type": "number" },
        "shortMarks": { "type": "number" },
        "mcqMarks": { "type": "number" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["creative", "short", "mcq"] },
              "stimulus": { "type": "string" },
              "qA": { "type": "string" },
              "qB": { "type": "string" },
              "qC": { "type": "string" },
              "qD": { "type": "string" },
              "shortText": { "type": "string" },
              "mcqQuestion": { "type": "string" },
              "optA": { "type": "string" },
              "optB": { "type": "string" },
              "optC": { "type": "string" },
              "optD": { "type": "string" },
              "imageUrl": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "isMcq": { "type": "boolean" }
      },
      "required": ["userId", "classId", "subject"]
    },
    "LectureSheet": {
      "title": "Lecture Sheet",
      "description": "A study sheet or lecture note.",
      "type": "object",
      "properties": {
        "institution": { "type": "string" },
        "classId": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["userId", "classId", "subject", "topic"]
    },
    "Student": {
      "title": "Student",
      "description": "Information about a student.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "fatherName": { "type": "string" },
        "photo": { "type": "string", "description": "Base64 encoded student photo." },
        "classId": { "type": "string" },
        "roll": { "type": "string" },
        "phone": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "classId", "userId"]
    },
    "AttendanceRecord": {
      "title": "Attendance Record",
      "description": "Daily attendance status for a student managed by the teacher.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["present", "absent"] },
        "classId": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["userId", "studentId", "date", "status", "classId"]
    },
    "FeeRecord": {
      "title": "Fee Record",
      "description": "Payment record for student fees collected by teachers.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "month": { "type": "string" },
        "year": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["userId", "studentId", "amount", "month", "year"]
    },
    "AdminConfig": {
      "title": "Admin Config",
      "description": "Stores the UID of the first registered admin.",
      "type": "object",
      "properties": {
        "adminUid": { "type": "string" }
      }
    },
    "SoftwareConfig": {
      "title": "Software Config",
      "description": "Global settings for the application branding.",
      "type": "object",
      "properties": {
        "appName": { "type": "string" },
        "appLogoUrl": { "type": "string" }
      }
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores extended user profile information.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/books/{bookId}": {
      "schema": "Book",
      "description": "Collection of uploaded books metadata."
    },
    "/questions/{questionId}": {
      "schema": "QuestionSet",
      "description": "Stored question sets created by users."
    },
    "/lecture-sheets/{sheetId}": {
      "schema": "LectureSheet",
      "description": "Collection of study materials and lecture notes."
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Collection of students managed by the teacher."
    },
    "/attendance/{attendanceId}": {
      "schema": "AttendanceRecord",
      "description": "Daily attendance records linked to user IDs."
    },
    "/fees/{feeId}": {
      "schema": "FeeRecord",
      "description": "Payment records for student fees managed by users."
    },
    "/config/admin": {
      "schema": "AdminConfig",
      "description": "Global config to store the first admin's UID."
    },
    "/config/software": {
      "schema": "SoftwareConfig",
      "description": "Global software settings branding."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Stored user profile data."
    }
  }
}
